# --- Configuration ---
var owner = "Kingrashy12"
var repo = "zio"
var base_asset_name = "zio" # Prefix for all assets
var install_name    # Name of the executable after installation

if OS == "windows"
  install_name = "zio.exe"
else
  install_name = "zio"
end

echo "--- ZIO Universal Installer (Linux/macOS/Windows) ---"

echo "Detected OS: **$OS**"
echo "Detected Architecture: **$ARCH**"

# Construct Asset Name
var asset_name = "$base_asset_name-$ARCH-$OS"
echo "Target Asset Name: **$asset_name**"

# Fetch Latest Version
echo "Fetching latest version from GitHub..."
var latest_version_url = "https://api.github.com/repos/$owner/$repo/releases/latest"
var latest_version = exec("curl", "-s", $latest_version_url, "|", "grep", "tag_name", "|", "sed", "-E", "s/.*\"tag_name\": *\"([^\"}]+)\".*/\\1/")

if latest_version == ""
    echo "Error: Could not retrieve latest version tag."
    exit 1
end

echo "Latest version: **$latest_version**"

# Construct Download URL
var download_url = "https://github.com/$owner/$repo/releases/download/$latest_version/$asset_name"
echo "Downloading from: **$download_url**"

# Download the Asset
exec("curl", "-L", "-o", $asset_name, $download_url)

echo "Download complete."

# Determine Install Directory
var install_dir

if OS == "windows"
    install_dir = "$LOCALAPPDATA\Microsoft\WindowsApps"
else
    install_dir = "/usr/local/bin"
end

mkdir($install_dir)

echo "Installing to directory: **$install_dir**"

move($asset_name, "$install_dir/$install_name")

if OS != "windows"
    exec("chmod", "+x", "$install_dir/$install_name")
    echo "Set executable permissions."
end

echo "Installation complete as: **$install_dir/$install_name**\n"

# Verify installation
echo "Verifying installation..."
if exists("$install_dir/$install_name")
    echo "✅ Executable installed: $install_dir/$install_name"

    var file_size

    if OS == "windows"
        file_size = exec("powershell", "-Command", "(Get-Item '$install_dir/$install_name').Length")
    else
        file_size = exec("stat", "-f%z", "$install_dir/$install_name")
    end
    echo "✅ File size: $file_size bytes"
    
    var version_output
    # Try to get version info
    if exec("$install_dir/$install_name", "--version") != ""
        version_output = exec("$install_dir/$install_name", "--version")
        echo "✅ Version: $version_output"
    else if exec("$install_dir/$install_name", "version") != ""
        version_output = exec("$install_dir/$install_name", "version")
        echo "✅ Version: $version_output"
    end
else
    echo "❌ Installation failed. Executable not found at: $install_dir/$install_name"
    exit 1
end